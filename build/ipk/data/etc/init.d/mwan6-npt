#!/bin/sh /etc/rc.common

START=99
STOP=10

USE_PROCD=1
PROG=/usr/sbin/mwan6-npt

reload_service() {
    $PROG update
}

service_triggers() {
    procd_add_reload_trigger "mwan6-npt"
    procd_add_reload_interface_trigger "wan"
}

start_service() {
    local enabled
    config_load mwan6-npt
    config_get_bool enabled globals enabled 0
    
    [ "$enabled" -eq 1 ] || return 1
    
    procd_open_instance
    procd_set_param command $PROG update
    procd_set_param stderr 1
    procd_set_param stdout 1
    procd_close_instance
}

stop_service() {
    $PROG flush
}
