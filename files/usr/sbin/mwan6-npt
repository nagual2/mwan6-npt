#!/bin/sh
# mwan6-npt - NPTv6 rule generator for Multi-WAN
# Manages prefix translation rules for active IPv6 WAN interfaces

. /lib/functions.sh
. /usr/share/mwan6-npt/functions.sh

CONFIG="mwan6-npt"
CHAIN_POST_DIR="/usr/share/nftables.d/chain-post"
SRCNAT_FILE="${CHAIN_POST_DIR}/srcnat/99-mwan6-npt.nft"
DSTNAT_FILE="${CHAIN_POST_DIR}/dstnat/99-mwan6-npt.nft"

log() {
    logger -t mwan6-npt "$1"
    echo "$1" >&2
}

find_lan_prefix() {
    local cfg="$1"
    local enabled=""
    local wan_prefix=""
    local is_default=""
    
    config_get enabled "$cfg" enabled 0
    config_get wan_prefix "$cfg" wan_prefix ""
    config_get is_default "$cfg" default 0
    
    [ "$enabled" -eq 1 ] || return 0
    [ "$is_default" -eq 1 ] || return 0
    [ -n "$wan_prefix" ] || return 0
    
    LAN_PREFIX="$wan_prefix"
}

load_config() {
    config_load "$CONFIG"
    LAN_PREFIX=""
    config_foreach find_lan_prefix interface
}

generate_rules() {
    local enabled="0"
    local wan_prefix=""
    local active_count=0
    
    load_config
    
    [ -n "$LAN_PREFIX" ] || {
        log "Error: No default interface configured"
        return 1
    }
    
    # Ensure directories exist
    mkdir -p "${CHAIN_POST_DIR}/srcnat"
    mkdir -p "${CHAIN_POST_DIR}/dstnat"
    
    # Clear old rules
    > "$SRCNAT_FILE"
    > "$DSTNAT_FILE"
    
    log "Generating NPTv6 rules for LAN prefix $LAN_PREFIX"
    
    process_interface() {
        local cfg="$1"
        local iface="$2"
        local is_default=""
        
        config_get enabled "$cfg" enabled 0
        config_get wan_prefix "$cfg" wan_prefix ""
        config_get is_default "$cfg" default 0
        
        [ "$enabled" -eq 1 ] || return 0
        [ -n "$wan_prefix" ] || return 0
        
        # Skip default interface (LAN side)
        [ "$is_default" -eq 1 ] && return 0
        
        # Check if interface exists and is UP
        if ip link show "$iface" 2>/dev/null | grep -q "LOWER_UP\|state UP"; then
            log "Active interface: $iface -> $wan_prefix"
            
            # SNAT: outgoing from LAN to WAN
            echo "oifname \"$iface\" ip6 saddr $LAN_PREFIX snat prefix to $wan_prefix;" >> "$SRCNAT_FILE"
            
            # DNAT: incoming from WAN to LAN
            echo "iifname \"$iface\" ip6 daddr $wan_prefix dnat prefix to $LAN_PREFIX;" >> "$DSTNAT_FILE"
            
            active_count=$((active_count + 1))
        else
            log "Interface $iface is down or not found"
        fi
    }
    
    config_foreach process_interface interface
    
    log "Generated rules for $active_count active interfaces"
    
    if [ $active_count -eq 0 ]; then
        log "Warning: No active interfaces found"
        return 1
    fi
    
    return 0
}

flush_rules() {
    log "Flushing mwan6-npt rules"
    > "$SRCNAT_FILE" 2>/dev/null
    > "$DSTNAT_FILE" 2>/dev/null
    fw4 reload >/dev/null 2>&1
}

reload_firewall() {
    log "Reloading firewall"
    fw4 reload >/dev/null 2>&1
}

show_status() {
    load_config
    
    echo "=== mwan6-npt Status ==="
    echo "LAN prefix (default): $LAN_PREFIX"
    echo ""
    echo "Active SNAT rules (srcnat):"
    nft list chain inet fw4 srcnat 2>/dev/null | grep -E "snat prefix" || echo "  (none)"
    echo ""
    echo "Active DNAT rules (dstnat):"
    nft list chain inet fw4 dstnat 2>/dev/null | grep -E "dnat prefix" || echo "  (none)"
    echo ""
    echo "Generated rule files:"
    [ -f "$SRCNAT_FILE" ] && echo "  $SRCNAT_FILE:" && cat "$SRCNAT_FILE"
    [ -f "$DSTNAT_FILE" ] && echo "  $DSTNAT_FILE:" && cat "$DSTNAT_FILE"
}

case "$1" in
    update)
        generate_rules && reload_firewall
        ;;
    flush)
        flush_rules
        ;;
    status)
        show_status
        ;;
    *)
        echo "Usage: $0 {update|flush|status}"
        exit 1
        ;;
esac
